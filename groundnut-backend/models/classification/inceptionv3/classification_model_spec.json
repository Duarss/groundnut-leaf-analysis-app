{
  "cmd": "train",
  "backbone": "inceptionv3",
  "img_size": [
    224,
    224
  ],
  "train_dir": "datasets/processed/classification_dataset\\train_balanced",
  "val_dir": "datasets/processed/classification_dataset\\val",
  "test_dir": "datasets/processed/classification_dataset\\test",
  "batch_size": 16,
  "epochs_phase1": 3,
  "epochs_phase2": 45,
  "weights": "models/classification\\inceptionv3\\best_classification_model.weights.h5",
  "class_indices": "models/classification\\inceptionv3\\classification_class_indices.json",
  "best_tuned_cfg": {
    "head": {
      "head_type": "mlp2",
      "dense_units": 256,
      "drop1": 0.3,
      "drop2": 0.3,
      "dense_l2": 1e-05,
      "dense_units2": 128,
      "drop3": 0.3
    },
    "schedule": {
      "lr_phase1": 0.001,
      "lr_phase2": 3e-05,
      "unfreeze_last_n_layers": 60
    }
  }
}